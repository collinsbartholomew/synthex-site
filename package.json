{
  "name": "synthex-site",
  "version": "0.1.0",
  "private": true,
  "packageManager": "pnpm@11.3.0",
  "scripts": {
    "dev": "turbo run dev --parallel",
    "dev:web": "pnpm --filter @ai-site/web dev",
    "dev:worker": "pnpm --filter @ai-site/worker dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "clean": "turbo run clean",
    "format": "pnpm --filter @ai-site/web exec prettier --write .",
    "update": "npx npm-check-updates@latest -u"
  },
  "devDependencies": {
    "@types/node": "^26.0.1",
    "prettier": "^3.9.3",
    "turbo": "^2.10.0"
  }
}
